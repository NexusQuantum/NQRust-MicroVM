{
  "name": "Auth",
  "description": "Authentication APIs.",
  "endpoints": [
    {
      "tag": "Auth",
      "path": "/v1/auth/login",
      "method": "POST",
      "slug": "post-auth-login",
      "operationId": "login",
      "security": true,
      "parameters": [],
      "requestBody": {
        "type": "object",
        "properties": {
          "password": {
            "type": "string"
          },
          "username": {
            "type": "string"
          }
        },
        "required": [
          "username",
          "password"
        ]
      },
      "requestBodyRequired": true,
      "responses": [
        {
          "status": "200",
          "description": "Login successful",
          "schema": {
            "type": "object",
            "properties": {
              "token": {
                "type": "string"
              },
              "user": {
                "type": "object",
                "properties": {
                  "avatar_path": {
                    "type": "string",
                    "nullable": true
                  },
                  "created_at": {
                    "type": "string",
                    "format": "date-time"
                  },
                  "id": {
                    "type": "string",
                    "format": "uuid"
                  },
                  "last_login_at": {
                    "type": "string",
                    "format": "date-time",
                    "nullable": true
                  },
                  "role": {
                    "type": "string",
                    "description": "(Role)"
                  },
                  "theme": {
                    "type": "string",
                    "nullable": true
                  },
                  "timezone": {
                    "type": "string",
                    "nullable": true
                  },
                  "username": {
                    "type": "string"
                  }
                },
                "required": [
                  "id",
                  "username",
                  "role",
                  "created_at"
                ]
              }
            },
            "required": [
              "token",
              "user"
            ]
          }
        },
        {
          "status": "401",
          "description": "Invalid credentials"
        },
        {
          "status": "500",
          "description": "Failed to authenticate"
        }
      ]
    },
    {
      "tag": "Auth",
      "path": "/v1/auth/me",
      "method": "GET",
      "slug": "get-auth-me",
      "operationId": "me",
      "security": true,
      "parameters": [],
      "responses": [
        {
          "status": "200",
          "description": "Current user info",
          "schema": {
            "type": "object",
            "properties": {
              "avatar_path": {
                "type": "string",
                "nullable": true
              },
              "created_at": {
                "type": "string",
                "format": "date-time"
              },
              "id": {
                "type": "string",
                "format": "uuid"
              },
              "last_login_at": {
                "type": "string",
                "format": "date-time",
                "nullable": true
              },
              "role": {
                "type": "string",
                "description": "(Role)"
              },
              "theme": {
                "type": "string",
                "nullable": true
              },
              "timezone": {
                "type": "string",
                "nullable": true
              },
              "username": {
                "type": "string"
              }
            },
            "required": [
              "id",
              "username",
              "role",
              "created_at"
            ]
          }
        },
        {
          "status": "401",
          "description": "Unauthorized"
        },
        {
          "status": "500",
          "description": "Failed to fetch user"
        }
      ]
    }
  ]
}